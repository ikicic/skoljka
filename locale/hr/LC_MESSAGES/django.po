#: skoljka/apps/accounts/simple_views.px:11 skoljka/components/layout.px:242
msgid "About"
msgstr "O nama"

#: skoljka/apps/accounts/simple_views.px:15
msgid ""
"Browse problems by source, topic, or search. Track your progress, bookmark "
"problems, and take notes."
msgstr ""
"Pregledavajte zadatke po izvoru, temi ili pretraživanjem. Pratite napredak, "
"spremajte zadatke i pišite bilješke."

#: skoljka/apps/accounts/simple_views.px:20
msgid "Contact: "
msgstr "Kontakt: "

#: skoljka/apps/accounts/simple_views.px:22
msgid "email"
msgstr "e-mail"

#: skoljka/apps/accounts/simple_views.px:32
msgid "Privacy Policy"
msgstr "Pravila privatnosti"

#: skoljka/apps/accounts/simple_views.px:35
msgid ""
"Školjka stores the information needed to run your account, including your "
"username, email address, profile settings, saved problems, solving progress, "
"likes, lists, notes, and uploaded content."
msgstr ""
"Školjka pohranjuje podatke potrebne za rad vašeg računa, uključujući "
"korisničko ime, e-mail adresu, postavke profila, spremljene zadatke, "
"napredak u rješavanju, oznake sviđanja, popise, bilješke i preneseni sadržaj."

#: skoljka/apps/accounts/simple_views.px:42
msgid ""
"We use this data to provide the service, keep the site secure, and improve "
"the application. We do not sell personal data."
msgstr ""
"Te podatke koristimo za pružanje usluge, održavanje sigurnosti stranice i "
"poboljšavanje aplikacije. Ne prodajemo osobne podatke."

#: skoljka/apps/accounts/simple_views.px:48
msgid ""
"You may contact the site administrators to request account deletion or "
"correction of your personal data."
msgstr ""
"Možete se obratiti administratorima stranice kako biste zatražili brisanje "
"računa ili ispravak svojih osobnih podataka."

#: skoljka/apps/accounts/simple_views.px:59
msgid "Terms of Use"
msgstr "Uvjeti korištenja"

#: skoljka/apps/accounts/simple_views.px:62
msgid ""
"Školjka is provided as an educational problem archive. Use the site "
"responsibly and do not upload unlawful, abusive, or misleading content."
msgstr ""
"Školjka se pruža kao obrazovna arhiva zadataka. Koristite stranicu odgovorno "
"i nemojte prenositi nezakonit, uvredljiv ili obmanjujući sadržaj."

#: skoljka/apps/accounts/simple_views.px:68
msgid ""
"Problem statements and other materials may be subject to copyright. By "
"adding content, you confirm that you have the right to share it or that your "
"use is otherwise lawful."
msgstr ""
"Tekstovi zadataka i drugi materijali mogu biti zaštićeni autorskim pravom. "
"Dodavanjem sadržaja potvrđujete da ga imate pravo dijeliti ili da je vaše "
"korištenje na drugi način zakonito."

#: skoljka/apps/accounts/simple_views.px:75
msgid ""
"The service is provided without warranty. We may remove content or restrict "
"accounts when needed to protect the site and its users."
msgstr ""
"Usluga se pruža bez jamstva. Možemo ukloniti sadržaj ili ograničiti račune "
"kada je to potrebno radi zaštite stranice i njezinih korisnika."

