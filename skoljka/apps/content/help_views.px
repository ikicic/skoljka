        "intro": "Problem statements and notes use Markdown with LaTeX math and a small set of LaTeX-style text commands.",
        "feature": "Feature",
        "code": "Code",
        "rendered": "Rendered",
        "notes": "Notes",
        "note_items": [
            "Use $...$ for inline math and $$...$$ for display math.",
